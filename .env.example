# Copy this file to ".env" and fill in your own keys.
# The app works fully with Ollama (local, free) if you don't have an OpenAI key.

# Required only if you want to use OpenAI models (GPT-4o, GPT-4o-mini, etc.)
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: base URL override (leave blank unless using a proxy/Azure)
OPENAI_BASE_URL=

# Optional: Ollama host if not running on default localhost:11434
OLLAMA_HOST=http://localhost:11434
